#!/bin/bash
# Variables de entorno para terminales
# Check if variable is set, load the config if it doesn't
[[ -n "$BASE_CONFIG_LOADED" ]] && return
export BASE_CONFIG_LOADED=1

# vim as the default editor
export EDITOR='nvim'

# Colored GCC warnings and errors
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

#tmuxp config dir (tmux session management)
export TMUXP_CONFIGDIR=~/.tmux/sessions/

# Starship
export STARSHIP_CONFIG=~/.shell_config/starship.toml

# Private config
PRIVATE_CONFIG="$HOME/shell_config/private-config/"
CONFIG_FILE="bashrc"

# Loop through each item in PRIVATE_CONFIG
for dir in "$PRIVATE_CONFIG"/*; do
  # Check that it's a directory and contains the expected file
  if [[ -d "$dir" && -f "$dir/$CONFIG_FILE" ]]; then
    echo "🔧 Sourcing $dir/$CONFIG_FILE"
    # shellcheck source=/dev/null
    source "$dir/$CONFIG_FILE"
  else
    # Show error if no config file in place
    echo "⚠️  Warning: '$CONFIG_FILE' not found in $dir"
  fi
done

# FZF
# shellcheck disable=SC1090
if [[ ! "$PATH" == *$HOME/.fzf/bin* ]]; then
  export PATH="${PATH:+${PATH}:}$HOME/.fzf/bin"
fi
export FZF_DEFAULT_COMMAND='rg --files --hidden --follow'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_DEFAULT_OPTS='--height 96% --reverse --preview "cat {}"'

# Exporting personalized commands to path
export PATH=~/.shell_config/commands:$PATH

# GO PATH
export GOPATH=$HOME/go:/home/juanito/repo/
export PATH=~/go/bin:/usr/local/go/bin:$PATH

# solana
export PATH="$HOME/.local/share/solana/install/active_release/bin:$PATH"

# Python env

# Node env
export NVM_DIR="$HOME/.nvm"
# shellcheck disable=SC1091 disable=1090
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
